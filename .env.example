# ============================================================
# PowerTrack - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no repositório!
# ============================================================

# ─── Banco de Dados MongoDB ───────────────────────────────
MONGO_USERNAME=powertrack
MONGO_PASSWORD=powertrack123
MONGO_DATABASE=powertrack

# ─── Aplicação ────────────────────────────────────────────
# Perfil ativo: staging | production
APP_PROFILE=staging

# Porta exposta (staging: 8080, produção: 80)
APP_PORT=8080

# ─── Azure DevOps (usado no pipeline) ─────────────────────
# Configure como Secret Variables no Azure DevOps, não aqui
# AZURE_CONTAINER_REGISTRY=seuregistro.azurecr.io
# AZURE_RESOURCE_GROUP=powertrack-rg
# AZURE_WEBAPP_NAME_STAGING=powertrack-staging
# AZURE_WEBAPP_NAME_PROD=powertrack-producao
